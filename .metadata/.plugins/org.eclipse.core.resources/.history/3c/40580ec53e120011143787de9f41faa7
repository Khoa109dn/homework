#include <stdint.h>
#include <stdio.h>
#include "stm32f103xb.h"

#define ADXL345_ADDR    0x53
#define REG_POWER_CTL   0x2D
#define REG_DATA_FORMAT 0x31
#define REG_DATAX0      0x32

void UART1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_USART1EN;
    GPIOA->CRH &= ~(0xFF << 4);
    GPIOA->CRH |=  (0x4B << 4);
    // Voi HSI 8MHz, Baud 9600 -> BRR = 8000000/9600 = 833 (0x341)
    USART1->BRR = 0x341;
    USART1->CR1 |= USART_CR1_TE | USART_CR1_UE;
}

void UART1_Print(char* str) {
    while(*str) {
        while(!(USART1->SR & USART_SR_TXE));
        USART1->DR = *str++;
    }
}

void I2C1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPBEN | RCC_APB2ENR_AFIOEN;
    RCC->APB1ENR |= RCC_APB1ENR_I2C1EN;
    GPIOB->CRL &= ~(0xFF000000);
    GPIOB->CRL |=  (0xFF000000);
    I2C1->CR1 |= I2C_CR1_SWRST;
    I2C1->CR1 &= ~I2C_CR1_SWRST;
    I2C1->CR2 = 8;     // HSI = 8MHz
    I2C1->CCR = 40;    // 100kHz
    I2C1->TRISE = 9;
    I2C1->CR1 |= I2C_CR1_PE;
}

int main(void) {
    UART1_Init();
    I2C1_Init();

    // Test UART truoc
    for(int i=0; i<5; i++) {
        UART1_Print("UART OK - DANG KET NOI ADXL...\r\n");
    }

    // Khoi tao ADXL (Co the treo tai day neu phan cung loi)
    I2C1->CR1 |= I2C_CR1_START;
    while(!(I2C1->SR1 & I2C_SR1_SB));
    I2C1->DR = (ADXL345_ADDR << 1);
    while(!(I2C1->SR1 & I2C_SR1_ADDR));
    (void)I2C1->SR2;
    I2C1->DR = REG_POWER_CTL;
    while(!(I2C1->SR1 & I2C_SR1_TXE));
    I2C1->DR = 0x08;
    while(!(I2C1->SR1 & I2C_SR1_BTF));
    I2C1->CR1 |= I2C_CR1_STOP;

    char buf[64];
    int16_t x, y, z;
    uint8_t d[6];

    while(1) {
        I2C1->CR1 |= I2C_CR1_START;
        while(!(I2C1->SR1 & I2C_SR1_SB));
        I2C1->DR = (ADXL345_ADDR << 1);
        while(!(I2C1->SR1 & I2C_SR1_ADDR));
        (void)I2C1->SR2;
        I2C1->DR = REG_DATAX0;
        while(!(I2C1->SR1 & I2C_SR1_TXE));
        I2C1->CR1 |= I2C_CR1_START;
        while(!(I2C1->SR1 & I2C_SR1_SB));
        I2C1->DR = (ADXL345_ADDR << 1) | 1;
        while(!(I2C1->SR1 & I2C_SR1_ADDR));
        (void)I2C1->SR2;
        I2C1->CR1 |= I2C_CR1_ACK;
        for(int i=0; i<6; i++) {
            if(i == 5) { I2C1->CR1 &= ~I2C_CR1_ACK; I2C1->CR1 |= I2C_CR1_STOP; }
            while(!(I2C1->SR1 & I2C_SR1_RXNE));
            d[i] = I2C1->DR;
        }

        x = (int16_t)(d[1] << 8 | d[0]);
        y = (int16_t)(d[3] << 8 | d[2]);
        z = (int16_t)(d[5] << 8 | d[4]);

        sprintf(buf, "X:%d Y:%d Z:%d\r\n", x, y, z);
        UART1_Print(buf);

        for(volatile int i=0; i<500000; i++);
    }
}
