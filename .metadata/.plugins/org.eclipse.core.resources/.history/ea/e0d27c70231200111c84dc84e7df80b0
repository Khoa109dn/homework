#include <stdint.h>

/* --- Định nghĩa địa chỉ Base --- */
#define RCC_BASE      0x40021000UL
#define GPIOA_BASE    0x40010800UL
#define GPIOC_BASE    0x40011000UL

/* --- Thanh ghi Clock (RCC) --- */
#define RCC_APB2ENR   (*(volatile uint32_t *)(RCC_BASE + 0x18UL))

/* --- Thanh ghi Port C (Cho LED PC13) --- */
#define GPIOC_CRH     (*(volatile uint32_t *)(GPIOC_BASE + 0x04UL))
#define GPIOC_ODR     (*(volatile uint32_t *)(GPIOC_BASE + 0x0CUL))

/* --- Thanh ghi Port A (Cho Nút nhấn PA0) --- */
#define GPIOA_CRL     (*(volatile uint32_t *)(GPIOA_BASE + 0x00UL))
#define GPIOA_IDR     (*(volatile uint32_t *)(GPIOA_BASE + 0x08UL))
#define GPIOA_ODR     (*(volatile uint32_t *)(GPIOA_BASE + 0x0CUL))

/* --- Cấu hình GPIO --- */
void GPIO_Init(void) {
    // 1. Bật Clock cho Port A (nút nhấn) và Port C (LED)
    // IOPA EN là bit 2, IOPC EN là bit 4
    RCC_APB2ENR |= (1U << 2) | (1U << 4);

    // 2. Cấu hình PC13: Output Push-Pull, Max speed 2MHz (Để điều khiển LED)
    // Xóa 4 bit cấu hình của chân 13 (bit 20 đến 23)
    GPIOC_CRH &= ~(0xFU << 20);
    // Thiết lập Mode = 10 (Output 2MHz), CNF = 00 (Push-pull) -> 0x2
    GPIOC_CRH |= (0x2U << 20);

    // 3. Cấu hình PA0: Input với Pull-up/Pull-down (Để đọc nút nhấn)
    // Xóa 4 bit cấu hình của chân 0 (bit 0 đến 3)
    GPIOA_CRL &= ~(0xFU << 0);
    // Thiết lập Mode = 00 (Input), CNF = 10 (Input with pull-up/down) -> 0x8
    GPIOA_CRL |= (0x8U << 0);

    // Chọn chế độ PULL-UP (Kéo lên 3.3V) bằng cách ghi 1 vào ODR chân PA0
    // Khi chưa nhấn nút, chân PA0 sẽ luôn ở mức 1.
    GPIOA_ODR |= (1U << 0);
}

int main(void) {
    // Khởi tạo các chân cắm
    GPIO_Init();

    while (1) {
        // Kiểm tra thanh ghi IDR của Port A
        // Nếu bit 0 bằng 0 (Nút nhấn nối PA0 xuống GND)
        if (!(GPIOA_IDR & (1U << 0))) {
            // BẬT LED: PC13 trên Blue Pill sáng khi kéo xuống mức 0 (Low)
            GPIOC_ODR &= ~(1U << 13);
        }
        else {
            // TẮT LED: PC13 tắt khi ở mức 1 (High)
            GPIOC_ODR |= (1U << 13);
        }
    }
}
