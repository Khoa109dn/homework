#include <stdint.h>
#include <stdio.h>
#include "stm32f103xb.h"

void UART1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_USART1EN;
    GPIOA->CRH &= ~(0xFF << 4);
    GPIOA->CRH |=  (0x4B << 4);
    USART1->BRR = 0x341;
    USART1->CR1 |= USART_CR1_TE | USART_CR1_UE;
}

void UART1_Print(char* str) {
    while(*str) {
        while(!(USART1->SR & USART_SR_TXE));
        USART1->DR = *str++;
    }
}

void ADC1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_ADC1EN;
    GPIOA->CRL &= ~(0xF << 0); // PA0 là Analog Input
    ADC1->SQR3 = 0;
    ADC1->SMPR2 |= (0x7 << 0); // Tăng thời gian lấy mẫu để ổn định
    ADC1->CR2 |= ADC_CR2_ADON;
    for(volatile int i=0; i<1000; i++);
    ADC1->CR2 |= ADC_CR2_ADON;
    ADC1->CR2 |= ADC_CR2_CAL;
    while(ADC1->CR2 & ADC_CR2_CAL);
}

uint16_t ADC_Read(void) {
    ADC1->CR2 |= ADC_CR2_ADON;
    while(!(ADC1->SR & ADC_SR_EOC));
    return ADC1->DR;
}

int main(void) {
    UART1_Init();
    ADC1_Init();

    char buf[64];
    uint32_t sum;

    UART1_Print("\r\nKiem tra nhiet do LM35...\r\n");

    while(1) {
        sum = 0;
        // Doc 20 lan lay trung binh cho do nhay
        for(int i=0; i<20; i++) {
            sum += ADC_Read();
            for(volatile int j=0; j<2000; j++);
        }
        uint16_t avg_adc = sum / 20;

        // Tinh toan kieu so nguyen (tranh dung float)
        // Millivolt = (avg_adc * 3300) / 4095
        uint32_t mVolt = (avg_adc * 3300) / 4095;
        uint32_t temp_int = mVolt / 10;      // Phan nguyen
        uint32_t temp_dec = mVolt % 10;      // Phan thap phan

        sprintf(buf, "ADC: %d | Temp: %d.%d C\r\n", avg_adc, (int)temp_int, (int)temp_dec);
        UART1_Print(buf);

        for(volatile int i=0; i<2000000; i++);
    }
}
