#define RCC_BASE 0x40021000UL
#define GPIOC_BASE 0x40011000UL

#define RCC_APB2ENR (*(volatile unsigned int *)(RCC_BASE + 0x18UL))
#define GPIOC_CRH (*(volatile unsigned int *)(GPIOC_BASE + 0x04UL))
#define GPIOC_ODR (*(volatile unsigned int *)(GPIOC_BASE + 0x0CUL))

#define GPIOCEN (1U<<4)
#define PIN13 (1U<<13)
#define LED_PIN PIN13



void GPIO_Init(void) {
	RCC_APB2ENR |= GPIOCEN;
    GPIOC_CRH &= ~(1U<<20);
    GPIOC_CRH |= (1U<<21);
}

int main(void) {
    GPIO_Init();
    while (1) {
    	for (int i = 0; i < 100000;i ++) {}
        GPIOC_ODR |= LED_PIN;

        for (int i = 0; i < 100000;i ++) {}
        GPIOC_ODR &= ~(LED_PIN);

    }
}
