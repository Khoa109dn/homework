#include <stdint.h>
#include <stdio.h>
#include "stm32f103xb.h"

void UART1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_USART1EN;
    GPIOA->CRH &= ~(0xFF << 4);
    GPIOA->CRH |=  (0x4B << 4);
    USART1->BRR = 0x341;
    USART1->CR1 |= USART_CR1_TE | USART_CR1_UE;
}

void UART1_Print(char* str) {
    while(*str) {
        while(!(USART1->SR & USART_SR_TXE));
        USART1->DR = *str++;
    }
}

void ADC1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_ADC1EN;
    GPIOA->CRL &= ~(0xF << 0);
    ADC1->CR2 |= ADC_CR2_ADON;
    for(volatile int i=0; i<5000; i++);
    ADC1->CR2 |= ADC_CR2_ADON;
    ADC1->CR2 |= ADC_CR2_CAL;
    while(ADC1->CR2 & ADC_CR2_CAL);
}

uint16_t ADC_Read(void) {
    ADC1->CR2 |= ADC_CR2_ADON;
    while(!(ADC1->SR & ADC_SR_EOC));
    return ADC1->DR;
}

int main(void) {
    UART1_Init();
    ADC1_Init();
    char buf[64];

    while(1) {
        uint32_t sum = 0;
        for(int i=0; i<100; i++) sum += ADC_Read();
        uint16_t avg_adc = sum / 100;

        // ÉP SỐ BẰNG TOÁN SỐ NGUYÊN (Không dùng float)
        // Giả sử lấy mốc 2000 ADC tương ứng 25.0 độ C
        // Mỗi đơn vị ADC thay đổi làm nhiệt độ tăng/giảm một chút
        int32_t temp_x10 = 250 + (avg_adc - 2000) / 5;

        int32_t phan_nguyen = temp_x10 / 10;
        int32_t phan_du = temp_x10 % 10;
        if(phan_du < 0) phan_du *= -1; // Đảm bảo phần dư luôn dương khi in

        // Dùng %d toàn bộ, không dùng %f
        sprintf(buf, "ADC: %d | Temp Fake: %d.%d C\r\n", (int)avg_adc, (int)phan_nguyen, (int)phan_du);
        UART1_Print(buf);

        for(volatile int i=0; i<2000000; i++);
    }
}
