#include <stdint.h>
#include <stdio.h>
#include "stm32f103xb.h"

void UART1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_USART1EN;
    GPIOA->CRH &= ~(0xFF << 4);
    GPIOA->CRH |=  (0x4B << 4);
    USART1->BRR = 0x341;
    USART1->CR1 |= USART_CR1_TE | USART_CR1_UE;
}

void UART1_Print(char* str) {
    while(*str) {
        while(!(USART1->SR & USART_SR_TXE));
        USART1->DR = *str++;
    }
}

void ADC1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_ADC1EN;
    GPIOA->CRL &= ~(0xF << 0);
    ADC1->CR2 |= ADC_CR2_ADON;
    for(volatile int i=0; i<5000; i++);
    ADC1->CR2 |= ADC_CR2_ADON;
    ADC1->CR2 |= ADC_CR2_CAL;
    while(ADC1->CR2 & ADC_CR2_CAL);
}

uint16_t ADC_Read(void) {
    ADC1->CR2 |= ADC_CR2_ADON;
    while(!(ADC1->SR & ADC_SR_EOC));
    return ADC1->DR;
}

int main(void) {
    UART1_Init();
    ADC1_Init();
    char buf[64];

    while(1) {
        uint32_t sum = 0;
        for(int i=0; i<50; i++) {
            sum += ADC_Read();
        }
        uint16_t avg_adc = sum / 50;

        // Voi LM35, 25 do C thi Out = 250mV.
        // ADC se doc duoc: (250 * 4095) / 3300 = 310.
        // Cong thuc tinh nguoc lai:
        float voltage_mv = (float)avg_adc * (3300.0f / 4095.0f);
        float temp = voltage_mv / 10.0f;

        // In ket qua (Dung kieu %d.%d neu float bi loi)
        int t_int = (int)temp;
        int t_dec = (int)(temp * 10) % 10;

        sprintf(buf, "ADC: %d | Temp: %d.%d C\r\n", avg_adc, t_int, t_dec);
        UART1_Print(buf);

        for(volatile int i=0; i<2000000; i++);
    }
}
