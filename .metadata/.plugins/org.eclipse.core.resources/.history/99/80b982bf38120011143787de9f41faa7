#include <stdint.h>
#include <stdio.h>
#include <string.h>
#include "stm32f103xb.h"

/* --- Cấu hình hệ thống --- */
#define ADXL345_ADDR_1    0x53
#define ADXL345_ADDR_2    0x1D
#define REG_POWER_CTL     0x2D
#define REG_DATA_FORMAT   0x31
#define REG_DATAX0        0x32

uint8_t current_addr = ADXL345_ADDR_1;

/* --- Prototypes --- */
void System_Init(void);
void UART1_SendString(char* str);
uint8_t I2C_Write(uint8_t devAddr, uint8_t reg, uint8_t data);
uint8_t I2C_ReadBurst(uint8_t devAddr, uint8_t reg, uint8_t *buffer, uint8_t size);

/* --- UART1: 115200 Baud --- */
void UART1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_USART1EN;
    GPIOA->CRH &= ~(0xFF << 4);
    GPIOA->CRH |=  (0x4B << 4); // PA9: AF Push-pull, PA10: Floating Input
    USART1->BRR = 0x271;        // 115200 @ 72MHz
    USART1->CR1 |= USART_CR1_TE | USART_CR1_RE | USART_CR1_UE;
}

void UART1_SendString(char* str) {
    while(*str) {
        while(!(USART1->SR & USART_SR_TXE));
        USART1->DR = (*str++ & 0xFF);
    }
}

/* --- I2C1: 100kHz --- */
void I2C1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPBEN | RCC_APB2ENR_AFIOEN;
    RCC->APB1ENR |= RCC_APB1ENR_I2C1EN;
    GPIOB->CRL &= ~(0xFF000000);
    GPIOB->CRL |=  (0xFF000000); // PB6, PB7: AF Open-drain
    I2C1->CR1 |= I2C_CR1_SWRST;
    I2C1->CR1 &= ~I2C_CR1_SWRST;
    I2C1->CR2 = 36;
    I2C1->CCR = 180;
    I2C1->TRISE = 37;
    I2C1->CR1 |= I2C_CR1_PE;
}

/* --- I2C Helper with Timeout --- */
uint8_t I2C_Write(uint8_t devAddr, uint8_t reg, uint8_t data) {
    uint32_t timeout = 100000;
    I2C1->CR1 |= I2C_CR1_START;
    while(!(I2C1->SR1 & I2C_SR1_SB) && timeout--);
    if(timeout == 0) return 1;

    I2C1->DR = (devAddr << 1);
    timeout = 100000;
    while(!(I2C1->SR1 & I2C_SR1_ADDR) && timeout--);
    if(timeout == 0) { I2C1->CR1 |= I2C_CR1_STOP; return 1; }
    (void)I2C1->SR2;

    I2C1->DR = reg;
    while(!(I2C1->SR1 & I2C_SR1_TXE));
    I2C1->DR = data;
    while(!(I2C1->SR1 & I2C_SR1_BTF));
    I2C1->CR1 |= I2C_CR1_STOP;
    return 0;
}

uint8_t I2C_ReadBurst(uint8_t devAddr, uint8_t reg, uint8_t *buffer, uint8_t size) {
    uint32_t timeout = 100000;
    I2C1->CR1 |= I2C_CR1_START;
    while(!(I2C1->SR1 & I2C_SR1_SB) && timeout--);

    I2C1->DR = (devAddr << 1);
    timeout = 100000;
    while(!(I2C1->SR1 & I2C_SR1_ADDR) && timeout--);
    if(timeout == 0) { I2C1->CR1 |= I2C_CR1_STOP; return 1; }
    (void)I2C1->SR2;

    I2C1->DR = reg;
    while(!(I2C1->SR1 & I2C_SR1_TXE));

    I2C1->CR1 |= I2C_CR1_START; // Restart
    while(!(I2C1->SR1 & I2C_SR1_SB));
    I2C1->DR = (devAddr << 1) | 1;
    while(!(I2C1->SR1 & I2C_SR1_ADDR));
    (void)I2C1->SR2;

    I2C1->CR1 |= I2C_CR1_ACK;
    for(int i=0; i<size; i++) {
        if(i == size-1) {
            I2C1->CR1 &= ~I2C_CR1_ACK;
            I2C1->CR1 |= I2C_CR1_STOP;
        }
        while(!(I2C1->SR1 & I2C_SR1_RXNE));
        buffer[i] = I2C1->DR;
    }
    return 0;
}

int main(void) {
    char msg[128];
    uint8_t raw_data[6];
    int16_t x, y, z;

    UART1_Init();
    I2C1_Init();

    UART1_SendString("\r\n--- ADXL345 System Start ---\r\n");

    // Thử khởi tạo với 0x53, nếu lỗi thử 0x1D
    if(I2C_Write(ADXL345_ADDR_1, REG_POWER_CTL, 0x08) != 0) {
        UART1_SendString("Address 0x53 failed, trying 0x1D...\r\n");
        current_addr = ADXL345_ADDR_2;
        if(I2C_Write(current_addr, REG_POWER_CTL, 0x08) != 0) {
            UART1_SendString("Critical Error: ADXL345 not found!\r\n");
            while(1); // Treo ở đây nếu không thấy cảm biến
        }
    }
    I2C_Write(current_addr, REG_DATA_FORMAT, 0x0B);
    UART1_SendString("ADXL345 Initialized OK!\r\n");

    while (1) {
        if(I2C_ReadBurst(current_addr, REG_DATAX0, raw_data, 6) == 0) {
            x = (int16_t)((raw_data[1] << 8) | raw_data[0]);
            y = (int16_t)((raw_data[3] << 8) | raw_data[2]);
            z = (int16_t)((raw_data[5] << 8) | raw_data[4]);

            sprintf(msg, "X: %5d  |  Y: %5d  |  Z: %5d\r\n", x, y, z);
            UART1_SendString(msg);
        } else {
            UART1_SendString("I2C Read Error!\r\n");
        }

        for(volatile int i=0; i<1000000; i++);
    }
}
