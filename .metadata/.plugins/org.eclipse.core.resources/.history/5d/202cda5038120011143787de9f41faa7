#include <stdint.h>
#include <stdio.h>
#include <string.h>
#include "stm32f103xb.h"

/* Cấu hình ADXL345 */
#define ADXL345_ADDR      0x53
#define REG_POWER_CTL     0x2D
#define REG_DATA_FORMAT   0x31
#define REG_DATAX0        0x32

/* Prototypes */
void I2C1_Init(void);
void UART1_Init(void);
void UART1_SendString(char* str);
void I2C_WriteReg(uint8_t devAddr, uint8_t reg, uint8_t data);
void ADXL345_ReadXYZ(int16_t *x, int16_t *y, int16_t *z);

/* --- UART Functions --- */
void UART1_Init(void) {
    // Bật clock cho Port A và USART1
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_USART1EN;

    // PA9 (TX1): Alternate function push-pull
    GPIOA->CRH &= ~(0xF << 4);
    GPIOA->CRH |=  (0xB << 4);

    // PA10 (RX1): Input floating
    GPIOA->CRH &= ~(0xF << 8);
    GPIOA->CRH |=  (0x4 << 8);

    // Baudrate 115200 @ 72MHz (PCLK2) -> BRR = 0x271
    USART1->BRR = 0x271;
    // Sửa lỗi ở đây: Dùng USART_CR1_... thay vì USART1_CR1_...
    USART1->CR1 |= USART_CR1_TE | USART_CR1_RE | USART_CR1_UE;
}

void UART1_SendString(char* str) {
    while(*str) {
        // Sửa lỗi ở đây: USART_SR_TXE
        while(!(USART1->SR & USART_SR_TXE));
        USART1->DR = (*str++ & 0xFF);
    }
}

/* --- I2C Functions --- */
static inline void i2c_wait_sb(void)    { while (!(I2C1->SR1 & I2C_SR1_SB)); }
static inline void i2c_wait_addr(void)  { while (!(I2C1->SR1 & I2C_SR1_ADDR)); (void)I2C1->SR2; }
static inline void i2c_wait_txe(void)   { while (!(I2C1->SR1 & I2C_SR1_TXE)); }
static inline void i2c_wait_rxne(void)  { while (!(I2C1->SR1 & I2C_SR1_RXNE)); }

void I2C1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPBEN | RCC_APB2ENR_AFIOEN;
    RCC->APB1ENR |= RCC_APB1ENR_I2C1EN;

    GPIOB->CRL &= ~(0xFF000000);
    GPIOB->CRL |=  (0xFF000000);

    I2C1->CR1 |= I2C_CR1_SWRST;
    I2C1->CR1 &= ~I2C_CR1_SWRST;

    I2C1->CR2 = 36;
    I2C1->CCR = 180;
    I2C1->TRISE = 37;
    I2C1->CR1 |= I2C_CR1_PE;
}

void I2C_WriteReg(uint8_t devAddr, uint8_t reg, uint8_t data) {
    I2C1->CR1 |= I2C_CR1_START;
    i2c_wait_sb();
    I2C1->DR = (devAddr << 1);
    i2c_wait_addr();
    I2C1->DR = reg;
    i2c_wait_txe();
    I2C1->DR = data;
    while (!(I2C1->SR1 & I2C_SR1_BTF));
    I2C1->CR1 |= I2C_CR1_STOP;
}

void ADXL345_ReadXYZ(int16_t *x, int16_t *y, int16_t *z) {
    uint8_t data[6];
    I2C1->CR1 |= I2C_CR1_START;
    i2c_wait_sb();
    I2C1->DR = (ADXL345_ADDR << 1);
    i2c_wait_addr();
    I2C1->DR = REG_DATAX0;
    i2c_wait_txe();

    I2C1->CR1 |= I2C_CR1_START;
    i2c_wait_sb();
    I2C1->DR = (ADXL345_ADDR << 1) | 1;
    i2c_wait_addr();

    I2C1->CR1 |= I2C_CR1_ACK;
    for (int i = 0; i < 6; i++) {
        if (i == 5) {
            I2C1->CR1 &= ~I2C_CR1_ACK;
            I2C1->CR1 |= I2C_CR1_STOP;
        }
        i2c_wait_rxne();
        data[i] = I2C1->DR;
    }
    *x = (int16_t)((data[1] << 8) | data[0]);
    *y = (int16_t)((data[3] << 8) | data[2]);
    *z = (int16_t)((data[5] << 8) | data[4]);
}

int main(void) {
    char msg[100];
    int16_t x, y, z;

    UART1_Init();
    I2C1_Init();

    UART1_SendString("ADXL345 Test via UART1...\r\n");

    // Khởi tạo ADXL345
    I2C_WriteReg(ADXL345_ADDR, REG_POWER_CTL, 0x08);
    I2C_WriteReg(ADXL345_ADDR, REG_DATA_FORMAT, 0x0B);

    while (1) {
        ADXL345_ReadXYZ(&x, &y, &z);

        // Chuyển dữ liệu sang chuỗi và gửi
        sprintf(msg, "Accel X:%d, Y:%d, Z:%d\r\n", x, y, z);
        UART1_SendString(msg);

        // Delay khoảng 200ms (tùy clock hệ thống)
        for(volatile int i=0; i<800000; i++);
    }
}
