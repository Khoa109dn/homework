#include <stdint.h>
#include <stdio.h>
#include "stm32f103xb.h"

#define ADXL345_ADDR    0x53
#define REG_POWER_CTL   0x2D
#define REG_DATA_FORMAT 0x31
#define REG_DATAX0      0x32

void Clock_Init(void) {
    RCC->CR |= RCC_CR_HSEON;
    while(!(RCC->CR & RCC_CR_HSERDY));
    RCC->CFGR |= (uint32_t)(0x00010000 | 0x001C0000);
    RCC->CFGR |= (uint32_t)0x00000400;
    RCC->CR |= RCC_CR_PLLON;
    while(!(RCC->CR & RCC_CR_PLLRDY));
    RCC->CFGR |= (uint32_t)0x00000002;
    while((RCC->CFGR & 0x0000000C) != 0x00000008);
}

void UART1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_USART1EN;
    GPIOA->CRH &= ~(0xFF << 4);
    GPIOA->CRH |=  (0x4B << 4);
    USART1->BRR = 0x271;
    USART1->CR1 |= USART_CR1_TE | USART_CR1_RE | USART_CR1_UE;
}

void UART1_Print(char* str) {
    while(*str) {
        while(!(USART1->SR & USART_SR_TXE));
        USART1->DR = *str++;
    }
}

void I2C1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPBEN | RCC_APB2ENR_AFIOEN;
    RCC->APB1ENR |= RCC_APB1ENR_I2C1EN;
    GPIOB->CRL &= ~(0xFF000000);
    GPIOB->CRL |=  (0xFF000000);
    I2C1->CR1 |= I2C_CR1_SWRST;
    I2C1->CR1 &= ~I2C_CR1_SWRST;
    I2C1->CR2 = 36;
    I2C1->CCR = 180;
    I2C1->TRISE = 37;
    I2C1->CR1 |= I2C_CR1_PE;
}

void I2C_Write(uint8_t reg, uint8_t data) {
    I2C1->CR1 |= I2C_CR1_START;
    while(!(I2C1->SR1 & I2C_SR1_SB));
    I2C1->DR = (ADXL345_ADDR << 1);
    while(!(I2C1->SR1 & I2C_SR1_ADDR));
    (void)I2C1->SR2;
    I2C1->DR = reg;
    while(!(I2C1->SR1 & I2C_SR1_TXE));
    I2C1->DR = data;
    while(!(I2C1->SR1 & I2C_SR1_BTF));
    I2C1->CR1 |= I2C_CR1_STOP;
}

int main(void) {
    Clock_Init();
    UART1_Init();
    I2C1_Init();

    UART1_Print("READY\r\n");

    I2C_Write(REG_POWER_CTL, 0x08);
    I2C_Write(REG_DATA_FORMAT, 0x0B);

    char buf[64];
    int16_t x, y, z;
    uint8_t d[6];

    while(1) {
        I2C1->CR1 |= I2C_CR1_START;
        while(!(I2C1->SR1 & I2C_SR1_SB));
        I2C1->DR = (ADXL345_ADDR << 1);
        while(!(I2C1->SR1 & I2C_SR1_ADDR));
        (void)I2C1->SR2;
        I2C1->DR = REG_DATAX0;
        while(!(I2C1->SR1 & I2C_SR1_TXE));

        I2C1->CR1 |= I2C_CR1_START;
        while(!(I2C1->SR1 & I2C_SR1_SB));
        I2C1->DR = (ADXL345_ADDR << 1) | 1;
        while(!(I2C1->SR1 & I2C_SR1_ADDR));
        (void)I2C1->SR2;

        I2C1->CR1 |= I2C_CR1_ACK;
        for(int i=0; i<6; i++) {
            if(i == 5) {
                I2C1->CR1 &= ~I2C_CR1_ACK;
                I2C1->CR1 |= I2C_CR1_STOP;
            }
            while(!(I2C1->SR1 & I2C_SR1_RXNE));
            d[i] = I2C1->DR;
        }

        x = (int16_t)(d[1] << 8 | d[0]);
        y = (int16_t)(d[3] << 8 | d[2]);
        z = (int16_t)(d[5] << 8 | d[4]);

        sprintf(buf, "X:%d Y:%d Z:%d\r\n", x, y, z);
        UART1_Print(buf);

        for(volatile int i=0; i<1000000; i++);
    }
}
