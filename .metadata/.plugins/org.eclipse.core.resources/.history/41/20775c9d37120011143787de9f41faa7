#include <stdint.h>
#include "stm32f103xb.h"

/* --- Cấu hình ADXL345 --- */
#define ADXL345_ADDR      0x53    // Địa chỉ I2C mặc định
#define REG_POWER_CTL     0x2D
#define REG_DATA_FORMAT   0x31
#define REG_DATAX0        0x32

/* --- Nguyên mẫu hàm --- */
void I2C1_Init(void);
void I2C_WriteReg(uint8_t devAddr, uint8_t reg, uint8_t data);
void I2C_ReadBurst(uint8_t devAddr, uint8_t reg, uint8_t *buffer, uint8_t size);
void ADXL345_Init(void);
void ADXL345_ReadXYZ(int16_t *x, int16_t *y, int16_t *z);

/* --- Các hàm đợi I2C --- */
static inline void i2c_wait_sb(void)    { while (!(I2C1->SR1 & I2C_SR1_SB)); }
static inline void i2c_wait_addr(void)  { while (!(I2C1->SR1 & I2C_SR1_ADDR)); (void)I2C1->SR2; }
static inline void i2c_wait_txe(void)   { while (!(I2C1->SR1 & I2C_SR1_TXE)); }
static inline void i2c_wait_rxne(void)  { while (!(I2C1->SR1 & I2C_SR1_RXNE)); }

/**
 * @brief Khởi tạo I2C1: PB6 (SCL), PB7 (SDA)
 */
void I2C1_Init(void) {
    // 1. Bật Clock GPIOB, I2C1 và AFIO
    RCC->APB2ENR |= RCC_APB2ENR_IOPBEN | RCC_APB2ENR_AFIOEN;
    RCC->APB1ENR |= RCC_APB1ENR_I2C1EN;

    // 2. Cấu hình PB6, PB7: Alternate Function Open-Drain (Mode: 11, CNF: 11 -> 0xF)
    GPIOB->CRL &= ~(0xFF000000);
    GPIOB->CRL |=  (0xFF000000);

    // 3. Reset bộ I2C
    I2C1->CR1 |= I2C_CR1_SWRST;
    I2C1->CR1 &= ~I2C_CR1_SWRST;

    // 4. Cấu hình tốc độ 100kHz (PCLK1 = 36MHz)
    I2C1->CR2 = 36;
    I2C1->CCR = 180;
    I2C1->TRISE = 37;

    // 5. Bật I2C
    I2C1->CR1 |= I2C_CR1_PE;
}

void I2C_WriteReg(uint8_t devAddr, uint8_t reg, uint8_t data) {
    I2C1->CR1 |= I2C_CR1_START;
    i2c_wait_sb();
    I2C1->DR = (devAddr << 1);
    i2c_wait_addr();
    I2C1->DR = reg;
    i2c_wait_txe();
    I2C1->DR = data;
    while (!(I2C1->SR1 & I2C_SR1_BTF));
    I2C1->CR1 |= I2C_CR1_STOP;
}

void I2C_ReadBurst(uint8_t devAddr, uint8_t reg, uint8_t *buffer, uint8_t size) {
    // Phase 1: Gửi địa chỉ thanh ghi
    I2C1->CR1 |= I2C_CR1_START;
    i2c_wait_sb();
    I2C1->DR = (devAddr << 1);
    i2c_wait_addr();
    I2C1->DR = reg;
    i2c_wait_txe();

    // Phase 2: Đọc dữ liệu (Restart)
    I2C1->CR1 |= I2C_CR1_START;
    i2c_wait_sb();
    I2C1->DR = (devAddr << 1) | 1;
    i2c_wait_addr();

    I2C1->CR1 |= I2C_CR1_ACK;
    for (uint8_t i = 0; i < size; i++) {
        if (i == size - 1) {
            I2C1->CR1 &= ~I2C_CR1_ACK; // NACK cho byte cuối
            I2C1->CR1 |= I2C_CR1_STOP;
        }
        i2c_wait_rxne();
        buffer[i] = I2C1->DR;
    }
}

void ADXL345_Init(void) {
    I2C_WriteReg(ADXL345_ADDR, REG_POWER_CTL, 0x08);   // Measure mode
    I2C_WriteReg(ADXL345_ADDR, REG_DATA_FORMAT, 0x0B); // Full resolution, 16g
}

void ADXL345_ReadXYZ(int16_t *x, int16_t *y, int16_t *z) {
    uint8_t data[6];
    I2C_ReadBurst(ADXL345_ADDR, REG_DATAX0, data, 6);

    // Dữ liệu ADXL345 là 16-bit dạng bù 2 (Little Endian)
    *x = (int16_t)((data[1] << 8) | data[0]);
    *y = (int16_t)((data[3] << 8) | data[2]);
    *z = (int16_t)((data[5] << 8) | data[4]);
}

int main(void) {
    int16_t x, y, z;

    I2C1_Init();
    ADXL345_Init();

    while (1) {
        ADXL345_ReadXYZ(&x, &y, &z);

        // Delay đơn giản để xem dữ liệu không bị nhảy quá nhanh
        for(volatile int i = 0; i < 500000; i++);
    }
}
